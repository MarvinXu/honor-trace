HONOR_PHONE=15872703899
HONOR_PASSWORD=your_password
HEADLESS=false
LOGIN_MODE=http

# MODE=once               单次查询（默认）
# MODE=serve              启动前端服务
# PORT=3000               前端服务端口
# POLL_INTERVAL=300       轮询间隔（秒，默认 300）
# ACCURACY_THRESHOLD=1000 精度阈值（米，超过此值丢弃，默认 1000）
# LOGIN_RETRY_COUNT=3     登录过期重试次数（默认 3）
# LOGIN_RETRY_INTERVAL=5000  重试间隔毫秒（默认 5000）
# DATA_DIR=data           位置数据存储目录（默认 data）
# SESSION_CACHE=.session-cache.json  session 缓存路径（多账号自动追加 -{phone}）
